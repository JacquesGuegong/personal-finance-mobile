# Copy to .env to override the API base URL.
# Must be prefixed EXPO_PUBLIC_ to be readable in the app (Expo inlines these at
# build time). NOTE: EXPO_PUBLIC_ values are embedded in the JS bundle, so they
# are NOT secret — never put real secrets here.
#
# Leave unset in normal dev: the app auto-detects your Mac's LAN host so a
# physical device can reach the local Spring Boot server. Set this to point at a
# deployed/staging API, or for production builds.
EXPO_PUBLIC_API_URL=https://your-aws-url.com
